# Environment Variables Template
# Copy this file to .env and fill in your actual values

# Django Settings
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# Allowed Hosts (comma-separated)
# For development: 127.0.0.1,localhost
# For production: yourdomain.com,www.yourdomain.com
ALLOWED_HOSTS=127.0.0.1,localhost

# Database (optional - defaults to SQLite)
# DATABASE_URL=postgresql://username:password@localhost:5432/database_name

# CORS Settings (comma-separated origins)
# For development: http://localhost:3000,http://127.0.0.1:3000
# For production: https://yourdomain.com,https://www.yourdomain.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8080,http://127.0.0.1:8080

# Additional Settings (optional)
# CACHE_TTL=300
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password
